# Required for FRED API requests
FRED_API_KEY=abcdefghijklmnopqrstuvxyz

# Required identification for SEC API requests
SEC_USER_AGENT="financial-risk-copilot your_email@example.com"

# Recommended SEC request settings
SEC_REQUEST_DELAY_SECONDS=0.2
SEC_REQUEST_TIMEOUT_SECONDS=30

# Ollama model used by the application LLM boundary
LLM_MODEL=qwen2.5-coder:7b

# Investment profile for trend analysis and risk adjustments
# Possible values: CONSERVATIVE, MODERATE, AGGRESSIVE
# CONSERVATIVE: ±10% trend sensitivity (preferred for cautious investors)
# MODERATE: ±15% trend sensitivity
# AGGRESSIVE: ±20% trend sensitivity (more responsive to metric trends)
INVESTMENT_PROFILE=CONSERVATIVE
